# Copy to .env and edit. Do not commit .env.

# Port the server listens on inside the container.
PORT=3000

# Secret used to sign session cookies. Generate something random, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared password for the simple gate. Anyone with this can log in.
# (Hashed at startup; you only set the plaintext here.)
APP_PASSWORD=change-me

# Where SQLite + session files live. Mounted as a volume in docker-compose.
DATA_DIR=/data

# Set to "true" once you've put the app behind HTTPS (Cloudflare Tunnel does this).
# Forces the session cookie to be Secure.
SECURE_COOKIES=true

# --- Optional: Google OAuth (leave blank to disable) ---
# Create an OAuth Client (Web application) in Google Cloud Console.
# Authorized redirect URI: https://<your-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails allowed to sign in via Google.
ALLOWED_EMAILS=
# Public base URL used for the OAuth redirect, e.g. https://menu.example.com
PUBLIC_BASE_URL=

# --- Optional: AI vision provider for photo analysis ---
#
# Supported providers (set AI_PROVIDER):
#   openai             — OpenAI cloud
#   anthropic          — Anthropic Claude cloud
#   ollama             — local Ollama (native API at /api/generate)
#   openai-compatible  — generic OpenAI-format endpoint (LM Studio, vLLM,
#                        Ollama's /v1 surface, etc.)
#   openrouter         — openrouter.ai (defaults base URL for you)
#   none               — disabled (default)
#
# Whatever provider you pick, the model must support vision (image input).
#
AI_PROVIDER=none
AI_API_KEY=
# Sensible default models per provider; override only if you know what you want:
#   openai            -> gpt-4o-mini
#   anthropic         -> claude-3-5-sonnet-latest
#   ollama            -> llava           (other vision options: bakllava, llama3.2-vision, gemma3:4b)
#   openrouter        -> openai/gpt-4o-mini
#   openai-compatible -> (you must set AI_MODEL)
AI_MODEL=
# Base URL override.
#
# Examples:
#   AI_BASE_URL=http://localhost:11434                    # local Ollama (native)
#   AI_BASE_URL=http://localhost:11434/v1                 # local Ollama via OpenAI surface — works with provider=ollama OR provider=openai-compatible
#   AI_BASE_URL=https://openrouter.ai/api/v1              # OpenRouter (auto-set when provider=openrouter)
#   AI_BASE_URL=https://api.openai.com                    # OpenAI default — /v1 is appended automatically
#   AI_BASE_URL=http://lm-studio.local:1234/v1            # LM Studio
#
# A trailing /v1 in the URL is detected automatically — both styles work.
AI_BASE_URL=

# --- Optional: Agent API tokens (Bearer auth for external agents) ---
# Comma-separated list of long random strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Anyone with a token can call /api/v1/agent/* without a browser session.
# IMPORTANT: do NOT wrap the value in quotes and do NOT add an inline # comment.
# docker-compose's env_file passes the value verbatim into the container, so
# quotes/comments become part of the token and auth will fail with 401.
# On startup the server logs: [agent-auth] N token(s) loaded: <prefix>…
AGENT_API_TOKENS=
