# Copy to .env and edit. Do not commit .env.

# Port the server listens on inside the container.
PORT=3000

# Secret used to sign session cookies. Generate something random, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared password for the simple gate. Anyone with this can log in.
# (Hashed at startup; you only set the plaintext here.)
APP_PASSWORD=change-me

# Where SQLite + session files live. Mounted as a volume in docker-compose.
DATA_DIR=/data

# Set to "true" once you've put the app behind HTTPS (Cloudflare Tunnel does this).
# Forces the session cookie to be Secure.
SECURE_COOKIES=true

# --- Optional: Google OAuth (leave blank to disable) ---
# Create an OAuth Client (Web application) in Google Cloud Console.
# Authorized redirect URI: https://<your-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails allowed to sign in via Google.
ALLOWED_EMAILS=
# Public base URL used for the OAuth redirect, e.g. https://menu.example.com
PUBLIC_BASE_URL=
